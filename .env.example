# ─── Production (Coolify + PostgreSQL) ───
DATABASE_URL=postgres://dashboard:YOUR_DB_PASSWORD@db:5432/dashboard
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=YOUR_STRONG_ADMIN_PASSWORD
# Required in production — random string, at least 16 characters (prefer 32+)
AUTH_SECRET=YOUR_RANDOM_AUTH_SECRET_AT_LEAST_16_CHARS
# Optional: force admin uploads onto a specific user
# Priority: USER_ID → EMAIL → name lookup
# DEFAULT_ADMIN_OWNER_USER_ID=
# DEFAULT_ADMIN_OWNER_EMAIL=tavanir@example.com
# DEFAULT_ADMIN_OWNER_NAME=توانیر
UPLOAD_DIR=/app/data/uploads
PORT=3030

# Local docker compose (copy these into a real .env next to docker-compose.yml)
# POSTGRES_USER=dashboard
# POSTGRES_PASSWORD=YOUR_DB_PASSWORD
# POSTGRES_DB=dashboard

# Map tiles — proxied by default for Iranian IPs (same-origin /api/map-tiles)
# Override with a direct tile URL if you use Neshan/Map.ir or another provider:
# NEXT_PUBLIC_MAP_TILE_URL=https://your-tile-provider/{z}/{x}/{y}.png
# MAP_TILE_UPSTREAM_URLS=https://a.basemaps.cartocdn.com/light_all/{z}/{x}/{y}.png

# Map Bilboard external API (billboard management system)
BILLBOARD_API_BASE_URL=https://billboard.pixlink.ir
# Option A: Sanctum token from Map-Bilboard admin login (DevTools → login response → data.token)
BILLBOARD_API_TOKEN=
# Option B: auto-login on server (recommended for production)
BILLBOARD_API_EMAIL=admin-username
BILLBOARD_API_PASSWORD=admin-password

# ─── Local dev against production DB (via SSH tunnel) ───
# 1. On server: ssh -L 5433:localhost:5432 user@your-server
# 2. Or expose Postgres temporarily in Coolify and use its host/port
# DATABASE_URL=postgres://dashboard:YOUR_DB_PASSWORD@127.0.0.1:5433/dashboard
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=YOUR_STRONG_ADMIN_PASSWORD
# AUTH_SECRET=same-as-production

# ─── Alternative: Supabase (only if DATABASE_URL is not set) ───
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
