# ─── Production (Coolify + PostgreSQL) ───
DATABASE_URL=postgres://dashboard:your-db-password@db:5432/dashboard
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=password
AUTH_SECRET=change-me-random-secret-min-32-chars
UPLOAD_DIR=/app/data/uploads
PORT=3030

# ─── Local dev against production DB (via SSH tunnel) ───
# 1. On server: ssh -L 5433:localhost:5432 user@your-server
# 2. Or expose Postgres temporarily in Coolify and use its host/port
# DATABASE_URL=postgres://dashboard:your-db-password@127.0.0.1:5433/dashboard
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=password
# AUTH_SECRET=same-as-production

# ─── Alternative: Supabase (only if DATABASE_URL is not set) ───
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
